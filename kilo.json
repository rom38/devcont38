{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "firecrawl": {
      "type": "local",
      "command": [
        "node", "/home/vscode/.local/lib/node_modules/firecrawl-mcp/dist/index.js"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      },
      "timeout": 10000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "node", "/home/vscode/.local/lib/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "permission": {
    "bash": "allow",
    "firecrawl_*": "allow",
    "context7_*": "allow"
  }
}
